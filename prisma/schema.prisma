// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum DocumentType {
  INVOICE
  PURCHASE_ORDER
  SURAT_JALAN
  SPH
}

enum DocumentStatus {
  DRAFT
  FINAL
}

enum DocumentLocale {
  EN
  ID
}

enum PaymentTermType {
  LUMP_SUM
  TERMIN
}

enum UserRole {
  ADMIN
  STAFF
  OFFICER
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         UserRole  @default(ADMIN)
  isActive     Boolean   @default(true)
  totpSecret   String?   @db.Text
  totpEnabled  Boolean   @default(false)
  emailVerified DateTime?
  image        String?
  accounts     Account[]
  sessions     Session[]
  invoices     Invoice[] @relation("InvoiceCreatedBy")
  purchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  suratJalans  SuratJalan[] @relation("SuratJalanCreatedBy")
  sphs         Sph[] @relation("SphCreatedBy")
  poMasuks     PoMasuk[] @relation("PoMasukCreatedBy")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Counterparty {
  id          String   @id @default(cuid())
  name        String
  address     String   @db.Text
  npwp        String?
  contactName String?
  phone       String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyProfile {
  id         String   @id @default(cuid())
  companyName String
  address    String   @db.Text
  phone      String?
  email      String?
  website    String?
  taxId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Company {
  id          String    @id @default(cuid())
  identifier  String    @unique @default(cuid())
  companyName String
  companyAlias String?
  address     String    @db.Text
  website     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  @@index([deletedAt])
}

model Invoice {
  id                    String         @id @default(cuid())
  status                DocumentStatus @default(DRAFT)
  locale                DocumentLocale @default(ID)
  documentNumber        String?        @unique
  duplicatedFromNumber  String?
  issueDate             DateTime
  dueDate               DateTime?
  referencePoNumber     String?
  referenceBastSjNumber String?
  customerReference     String?
  salesPerson           String?
  taxId                 String?
  paymentTerms          String?        @db.Text
  billToName            String?
  billToAddress         String?        @db.Text
  deliveredToName       String?
  deliveredToAddress    String?        @db.Text
  withSignature         Boolean        @default(true)
  createdById           String
  createdBy             User           @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  items                 InvoiceItem[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  deletedAt             DateTime?
  @@index([deletedAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  sortOrder   Int      @default(0)
  description String   @db.Text
  detail      String?  @db.Text
  quantity    Decimal  @db.Decimal(12, 2)
  unit        String?
  unitPrice   Decimal  @db.Decimal(15, 2)
  currency    String   @default("IDR")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchaseOrder {
  id                 String         @id @default(cuid())
  status             DocumentStatus @default(DRAFT)
  locale             DocumentLocale @default(ID)
  documentNumber     String?        @unique
  duplicatedFromNumber String?
  issueDate          DateTime
  taxId              String?
  paymentTermType    PaymentTermType @default(LUMP_SUM)
  paymentTerms       String?        @db.Text
  deliveryNotes      String?        @db.Text
  orderToName        String?
  orderToAddress     String?        @db.Text
  deliveredToName    String?
  deliveredToAddress String?        @db.Text
  withSignature      Boolean        @default(true)
  gdriveFileId       String?
  gdriveFileName     String?
  gdriveWebViewLink  String?
  createdById        String
  createdBy          User           @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  items              PurchaseOrderItem[]
  installments       PoPaymentInstallment[]
  poMasukLinks       PoMasukPurchaseOrderLink[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  @@index([deletedAt])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  sortOrder        Int           @default(0)
  description      String        @db.Text
  detail           String?       @db.Text
  quantity         Decimal       @db.Decimal(12, 2)
  unit             String?
  unitPrice        Decimal       @db.Decimal(15, 2)
  currency         String        @default("IDR")
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model SuratJalan {
  id             String         @id @default(cuid())
  status         DocumentStatus @default(DRAFT)
  locale         DocumentLocale @default(ID)
  documentNumber String?        @unique
  duplicatedFromNumber String?
  issueDate      DateTime
  referencePoNumber String?
  fromName       String?
  fromAddress    String?        @db.Text
  toName         String?
  toAddress      String?        @db.Text
  deliveryNotes  String?        @db.Text
  withSignature  Boolean        @default(true)
  createdById    String
  createdBy      User           @relation("SuratJalanCreatedBy", fields: [createdById], references: [id])
  items          SuratJalanItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  @@index([deletedAt])
}

model SuratJalanItem {
  id           String     @id @default(cuid())
  suratJalanId String
  sortOrder    Int        @default(0)
  description  String     @db.Text
  detail       String?    @db.Text
  quantity     Decimal    @db.Decimal(12, 2)
  unit         String?
  unitPrice    Decimal    @db.Decimal(15, 2)
  currency     String     @default("IDR")
  suratJalan   SuratJalan @relation(fields: [suratJalanId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Sph {
  id             String         @id @default(cuid())
  status         DocumentStatus @default(DRAFT)
  locale         DocumentLocale @default(ID)
  documentNumber String?        @unique
  duplicatedFromNumber String?
  issueDate      DateTime
  subject        String?
  recipientName  String?
  recipientCompany String?
  notes          Json?
  paymentTerms   String?        @db.Text
  salesPerson    String?
  withSignature  Boolean        @default(true)
  createdById    String
  createdBy      User           @relation("SphCreatedBy", fields: [createdById], references: [id])
  items          SphItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  @@index([deletedAt])
}

model SphItem {
  id        String   @id @default(cuid())
  sphId     String
  sortOrder Int      @default(0)
  description String @db.Text
  detail    String?  @db.Text
  quantity  Decimal  @db.Decimal(12, 2)
  unit      String?
  unitPrice Decimal  @db.Decimal(15, 2)
  currency  String   @default("IDR")
  sph       Sph      @relation(fields: [sphId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PoMasuk {
  id                 String    @id @default(cuid())
  poNumber           String?
  issueDate          DateTime?
  distributorName    String
  paymentTermType    PaymentTermType @default(LUMP_SUM)
  paymentTerms       String?   @db.Text
  totalAmount        Decimal?  @db.Decimal(15, 2)
  notes              String?   @db.Text
  gdriveFileId       String
  gdriveFileName     String?
  gdriveMimeType     String?
  gdriveWebViewLink  String?
  createdById        String
  createdBy          User      @relation("PoMasukCreatedBy", fields: [createdById], references: [id])
  installments       PoPaymentInstallment[]
  purchaseOrderLinks PoMasukPurchaseOrderLink[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  @@index([deletedAt])
}

model PoMasukPurchaseOrderLink {
  id              String        @id @default(cuid())
  poMasukId       String
  purchaseOrderId String
  poMasuk         PoMasuk       @relation(fields: [poMasukId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([poMasukId, purchaseOrderId])
  @@index([purchaseOrderId])
}

model PoPaymentInstallment {
  id              String         @id @default(cuid())
  poMasukId       String?
  purchaseOrderId String?
  sortOrder       Int            @default(0)
  label           String?
  percentage      Decimal        @db.Decimal(5, 2)
  amount          Decimal?       @db.Decimal(15, 2)
  dueDate         DateTime
  paidAt          DateTime?
  notes           String?        @db.Text
  poMasuk         PoMasuk?       @relation(fields: [poMasukId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([poMasukId])
  @@index([purchaseOrderId])
  @@index([dueDate, paidAt])
}
